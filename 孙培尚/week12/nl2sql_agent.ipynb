# 单元格1: 导入并连接数据库
import sqlite3

conn = sqlite3.connect('chinook.db')
cursor = conn.cursor()

# 单元格2: 查看有哪些表
cursor.execute("SELECT name FROM sqlite_master WHERE type='table';")
tables = cursor.fetchall()
print("数据库中的表:", [t[0] for t in tables])

# 单元格3: 实现问答函数
def answer_question(question):
    """回答自然语言问题"""
    
    # 提问1
    if '多少张表' in question:
        cursor.execute("SELECT COUNT(*) FROM sqlite_master WHERE type='table';")
        count = cursor.fetchone()[0]
        return f"数据库中共有 {count} 张表"
    
    # 提问2
    elif '员工表' in question and '多少条' in question:
        cursor.execute("SELECT COUNT(*) FROM employees;")
        count = cursor.fetchone()[0]
        return f"员工表中共有 {count} 条记录"
    
    # 提问3
    elif '客户个数' in question and '员工个数' in question:
        cursor.execute("SELECT (SELECT COUNT(*) FROM customers), (SELECT COUNT(*) FROM employees);")
        customer_count, employee_count = cursor.fetchone()
        return f"客户: {customer_count}个, 员工: {employee_count}个"
    
    return "抱歉，无法回答这个问题"

# 单元格4: 测试
print(answer_question("数据库中总共有多少张表"))
print(answer_question("员工表中有多少条记录"))
print(answer_question("数据库中所有客户个数和员工个数分别是多少"))
