"""
使用OpenAI Agents框架实现多Agent系统：
- 主Agent负责接收用户请求并选择合适的子Agent
- 子Agent 1: 文本情感分类
- 子Agent 2: 文本实体识别
"""

from openai import OpenAI
from agents import Agent, Runner, set_default_openai_api
import re
import json

# 设置OpenAI API
set_default_openai_api("chat_completions")

def detect_intent(text):
    """
    检测用户意图，决定调用哪个子Agent
    """
    text_lower = text.lower()
    
    # 关键词检测
    sentiment_keywords = ['情感', '情绪', '感觉', '评价', '态度', 'positive', 'negative', 'sentiment', 'feeling']
    entity_keywords = ['实体', '命名实体', '人名', '地名', '组织', '识别', 'extract', 'entity', 'named entity']
    
    sentiment_count = sum(1 for keyword in sentiment_keywords if keyword in text_lower)
    entity_count = sum(1 for keyword in entity_keywords if keyword in text_lower)
    
    if sentiment_count > entity_count:
        return "sentiment"
    elif entity_count > sentiment_count:
        return "entity"
    else:
        # 如果关键词数量相同或都没有，使用AI判断
        client = OpenAI()
        response = client.chat.completions.create(
            model="gpt-4o",
            messages=[
                {
                    "role": "user",
                    "content": f"分析以下文本的意图，如果是要求进行情感分析，请回复'sentiment'，如果是要求进行实体识别，请回复'entity'，文本：{text}"
                }
            ],
            max_tokens=10,
            temperature=0
        )
        
        intent = response.choices[0].message.content.strip().lower()
        if "sentiment" in intent or "情感" in intent:
            return "sentiment"
        elif "entity" in intent or "实体" in intent:
            return "entity"
        else:
            # 默认返回情感分析
            return "sentiment"

def analyze_sentiment(text):
    """
    执行情感分析
    """
    client = OpenAI()
    response = client.chat.completions.create(
        model="gpt-4o",
        messages=[
            {
                "role": "user",
                "content": f"请分析以下文本的情感倾向，返回json格式的结果，包含sentiment（positive/negative/neutral）和confidence（0-1之间的置信度）：{text}"
            }
        ],
        max_tokens=200,
        temperature=0.3
    )
    
    try:
        result_text = response.choices[0].message.content
        # 提取JSON部分
        json_match = re.search(r'\{.*\}', result_text, re.DOTALL)
        if json_match:
            result = json.loads(json_match.group())
        else:
            # 如果没有找到JSON，尝试解析整个响应
            result = {"sentiment": result_text, "confidence": 0.5}
    except Exception:
        result = {"sentiment": "unknown", "confidence": 0.0}
    
    return result

def extract_entities(text):
    """
    执行实体识别
    """
    client = OpenAI()
    response = client.chat.completions.create(
        model="gpt-4o",
        messages=[
            {
                "role": "user",
                "content": f"""请从以下文本中提取命名实体，返回json格式的结果，包含entities列表，每个实体包含text、type（PERSON, ORGANIZATION, LOCATION, OTHER）和confidence（0-1之间的置信度）：
                文本：{text}"""
            }
        ],
        max_tokens=300,
        temperature=0.3
    )
    
    try:
        result_text = response.choices[0].message.content
        # 提取JSON部分
        json_match = re.search(r'\[(.*)\]|\{.*\}', result_text, re.DOTALL)
        if json_match:
            result = json.loads(json_match.group())
            if isinstance(result, dict) and "entities" in result:
                entities = result["entities"]
            else:
                entities = result
        else:
            entities = []
    except Exception:
        entities = []
    
    return {"entities": entities}

# 定义情感分析Agent
sentiment_agent = Agent(
    name="Sentiment Analysis Agent",
    instructions="你是一个专门进行文本情感分析的AI助手。请分析输入文本的情感倾向（正面、负面或中性），并给出置信度。",
    functions=[analyze_sentiment],
    model="gpt-4o"
)

# 定义实体识别Agent
entity_agent = Agent(
    name="Entity Recognition Agent",
    instructions="你是一个专门进行命名实体识别的AI助手。请从输入文本中提取人名、地名、组织机构名等实体信息，并给出置信度。",
    functions=[extract_entities],
    model="gpt-4o"
)

# 定义主Agent
main_agent = Agent(
    name="Main Agent",
    instructions="""
    你是主AI助手，负责接收用户请求并决定将其转发给哪个子Agent。
    如果用户请求进行情感分析、情绪分析或评价分析，请使用handoff转接到情感分析Agent。
    如果用户请求进行实体识别、命名实体提取或信息抽取，请使用handoff转接到实体识别Agent。
    在handoff之前，先确认用户意图。
    """,
    functions=[detect_intent],
    model="gpt-4o"
)

def run_main_agent():
    """
    运行主Agent系统
    """
    print("=== 多Agent系统启动 ===")
    print("可用功能：情感分析、实体识别")
    print("请输入您的请求，或输入 'quit' 退出")
    print("-" * 50)
    
    while True:
        user_input = input("\n请输入您的请求: ").strip()
        
        if user_input.lower() == 'quit':
            print("再见！")
            break
        
        if not user_input:
            continue
            
        # 使用Runner运行主Agent
        runner = Runner(agent=main_agent)
        
        # 检测意图
        intent = detect_intent(user_input)
        
        print(f"\n检测到意图: {intent}")
        
        if intent == "sentiment":
            print("转接到情感分析Agent...")
            sentiment_runner = Runner(agent=sentiment_agent)
            result = sentiment_runner.run(user_input, max_turns=2)
            print(f"情感分析结果: {result.output}")
            
        elif intent == "entity":
            print("转接到实体识别Agent...")
            entity_runner = Runner(agent=entity_agent)
            result = entity_runner.run(user_input, max_turns=2)
            print(f"实体识别结果: {result.output}")
            
        else:
            # 默认使用情感分析
            print("未明确意图，使用默认情感分析...")
            sentiment_runner = Runner(agent=sentiment_agent)
            result = sentiment_runner.run(user_input, max_turns=2)
            print(f"情感分析结果: {result.output}")

if __name__ == "__main__":
    # 运行主系统
    run_main_agent()
